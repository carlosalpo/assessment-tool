{
  "name": "assessment-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test:ops": "node --test --experimental-strip-types lib/operational-assessment.test.ts",
    "test:ai": "node --test --experimental-strip-types lib/ai-analysis.test.ts lib/lifecycle-analysis.test.ts lib/ai-debug.test.ts lib/ai-design-guidelines.test.ts lib/ai-scope-brief.test.ts lib/ai-scope-engine.test.ts lib/ai-device-context.test.ts lib/ai-scope-schemas.test.ts lib/ai-status-labels.test.ts lib/ai-finding-summary.test.ts lib/ai-scope-ui.test.ts lib/ai-pipeline-view.test.ts",
    "test:eval": "node --test --experimental-strip-types eval/eval.test.ts",
    "test:navigation": "node --test --experimental-strip-types lib/assessment-navigation.test.ts",
    "test:templates": "node --test --experimental-strip-types lib/document-templates.test.ts lib/performance-analysis.test.ts lib/performance-visualization-service.test.ts lib/ai-analysis.test.ts",
    "worker:parse": "python3 worker/python/parse_cisco.py"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "scheduler": "^0.27.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
