DATABASE_URL="postgresql://assessment:assessment@localhost:5433/assessment_tool?schema=public"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_ANALYSIS_MODEL="gpt-5.2"
OPENAI_REDUCE_MODEL=""
OPENAI_SYNTHESIS_MODEL=""
OPENAI_MAX_INPUT_TOKENS="24000"
OPENAI_TIMEOUT_MS="90000"
# Set to "1" to persist structured scopeBrief artifacts and richer cross-scope memory.
AI_SCOPE_BRIEF=""
# Set to "1" to enable wired per-pattern OpenAI schemas/prompts for entity, graph, and aggregation scopes.
AI_PATTERN_QUERIES=""
# Set to "1" to keep top-ranked evidence fuller and derive default token budget by assessment size.
AI_EVIDENCE_TIERING=""
# Set to "1" to partition over-budget scopes by graph component or site before OpenAI calls.
AI_DOMAIN_PARTITION=""
# Set to "1" to pack ai-per-device scopes into whole-device batches before OpenAI calls.
AI_PER_DEVICE=""
# Set to "1" to evaluate ai-design scopes against editable topology design guidelines.
AI_DESIGN_RUBRIC=""
# Set to "1" to inject the configuration scope playbook and suppress excluded findings.
AI_SCOPE_PLAYBOOK=""
# Set to "1" to let lifecycle use deterministic HW/SW findings and AI narration only.
AI_DETERMINISTIC_LIFECYCLE=""
# Set to "1" to let operations use deterministic Tab 11 findings and AI narration only.
AI_DETERMINISTIC_OPERATIONS=""
# Set to "1" to run a cross-scope Reduce stage after full map jobs complete.
AI_REDUCE_STAGE=""
# Set to "1" to generate roadmap and executive summary in a post-reduce Synthesize stage.
AI_SYNTHESIS_STAGE=""
CREDENTIAL_ENCRYPTION_KEY=""
CISCO_API_TOKEN=""
