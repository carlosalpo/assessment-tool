DATABASE_URL="postgresql://assessment:assessment@localhost:5433/assessment_tool?schema=public"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_ANALYSIS_MODEL="gpt-5.2"
OPENAI_MAX_INPUT_TOKENS="24000"
OPENAI_TIMEOUT_MS="90000"
# Set to "1" to persist structured scopeBrief artifacts and richer cross-scope memory.
AI_SCOPE_BRIEF=""
# Set to "1" to enable wired per-pattern OpenAI schemas/prompts for entity, graph, and aggregation scopes.
AI_PATTERN_QUERIES=""
# Set to "1" to keep top-ranked evidence fuller and derive default token budget by assessment size.
AI_EVIDENCE_TIERING=""
# Set to "1" to partition over-budget scopes by graph component or site before OpenAI calls.
AI_DOMAIN_PARTITION=""
CREDENTIAL_ENCRYPTION_KEY=""
CISCO_API_TOKEN=""
